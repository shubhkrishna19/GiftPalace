<style>
.product-healing-benefits {
  margin: 0;
  padding: 0;
  background: transparent;
}

.healing-section {
  margin-bottom: 10px;
}

.healing-section:last-child {
  margin-bottom: 0;
}

.healing-title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 1.4rem;
  font-weight: 600;
  color: #2f2f2f;
  margin-bottom: 8px;
  letter-spacing: 0.02em;
}

.healing-audience,
.healing-benefits-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.healing-audience li,
.healing-benefits-list li {
  position: relative;
  padding-left: 18px;
  margin-bottom: 6px;
  font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 1rem;
  color: #555;
  line-height: 1.5;
}

.healing-audience li:before,
.healing-benefits-list li:before {
  content: '✦';
  position: absolute;
  left: 0;
  color: #8d5d48;
  font-size: 0.7rem;
}

@media (max-width: 767px) {
  .product-healing-benefits {
    margin: 0;
  }

  .healing-title {
    font-size: 1.25rem;
  }

  .healing-audience li,
  .healing-benefits-list li {
    font-size: 0.95rem;
  }
}
</style>
{% endif %}

