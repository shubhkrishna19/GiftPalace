<div class="home-conversion-section home-conversion-intro section-block-{{ section.id }}">
  <div class="{% if section.settings.container == 'fullwidth' %}container-full{% elsif section.settings.container == '1770' %}container-1770{% elsif section.settings.container == '1170' %}container-1170{% else %}container{% endif %}">
    <div class="home-conversion-shell home-conversion-reveal" style="padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;">
      <div class="home-conversion-inner home-conversion-grid">
        <div class="home-conversion-copy-column">
          {% if section.settings.eyebrow != blank %}
            <p class="home-conversion-kicker">{{ section.settings.eyebrow }}</p>
          {% endif %}

          {% if section.settings.title != blank %}
            <h1 class="home-conversion-heading">{{ section.settings.title }}</h1>
          {% endif %}

          {% if section.settings.copy != blank %}
            <div class="home-conversion-copy rte">
              {{ section.settings.copy }}
            </div>
          {% endif %}

          {% assign trust_blocks = section.blocks | where: 'type', 'trust_bullet' %}
          {% if trust_blocks.size > 0 %}
            <ul class="home-conversion-trust-list" style="margin-top: 28px;">
              {% for block in trust_blocks %}
                <li class="home-conversion-trust-item" {{ block.shopify_attributes }}>
                  {% if block.settings.title != blank %}
                    <span class="home-conversion-trust-title">{{ block.settings.title }}</span>
                  {% endif %}
                  {% if block.settings.text != blank %}
                    <span class="home-conversion-trust-text">{{ block.settings.text }}</span>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          {% endif %}

          {% if section.settings.primary_label != blank or section.settings.secondary_label != blank %}
            <div class="home-conversion-actions">
              {% if section.settings.primary_label != blank %}
                <a class="button home-conversion-button home-conversion-button--primary" {% if section.settings.primary_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ section.settings.primary_link }}"{% endif %}>
                  {{ section.settings.primary_label }}
                </a>
              {% endif %}
              {% if section.settings.secondary_label != blank %}
                <a class="button home-conversion-button home-conversion-button--secondary" {% if section.settings.secondary_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ section.settings.secondary_link }}"{% endif %}>
                  {{ section.settings.secondary_label }}
                </a>
              {% endif %}
            </div>
          {% endif %}

          {% assign shortcut_blocks = section.blocks | where: 'type', 'shortcut' %}
          {% if shortcut_blocks.size > 0 %}
            <div class="home-conversion-shortcuts">
              {% for block in shortcut_blocks %}
                <a class="home-conversion-shortcut" {% if block.settings.link == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.link }}"{% endif %} {{ block.shopify_attributes }}>
                  {{ block.settings.label }}
                </a>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <div class="home-conversion-panel">
          {% if section.settings.panel_kicker != blank %}
            <p class="home-conversion-kicker" style="margin-bottom: 14px;">{{ section.settings.panel_kicker }}</p>
          {% endif %}

          {% if section.settings.panel_title != blank %}
            <h2 class="home-conversion-panel-title">{{ section.settings.panel_title }}</h2>
          {% endif %}

          {% if section.settings.panel_copy != blank %}
            <div class="home-conversion-panel-copy rte">
              {{ section.settings.panel_copy }}
            </div>
          {% endif %}

          {% assign proof_blocks = section.blocks | where: 'type', 'proof_item' %}
          {% if proof_blocks.size > 0 %}
            <ul class="home-conversion-proof-list">
              {% for block in proof_blocks %}
                <li class="home-conversion-proof-item" {{ block.shopify_attributes }}>
                  {% if block.settings.label != blank %}
                    <span class="home-conversion-proof-label">{{ block.settings.label }}</span>
                  {% endif %}
                  {% if block.settings.text != blank %}
                    <span class="home-conversion-proof-text">{{ block.settings.text }}</span>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Home Conversion Intro",
  "tag": "section",
  "class": "section-home-conversion-intro",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Container",
      "default": "1770",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "1170", "label": "1170px" },
        { "value": "1770", "label": "1770px" },
        { "value": "fullwidth", "label": "Full width" }
      ]
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Gift with meaning"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "Meaningful gemstone jewellery, gifts, and crystal pieces that feel personal."
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Intro copy",
      "default": "<p>Explore curated gemstone jewellery, crystal accents, zodiac pieces, and gifting picks designed to help shoppers find something that feels intentional instead of generic.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary CTA label",
      "default": "Shop Bestsellers"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary CTA label",
      "default": "Browse by Intention"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary CTA link"
    },
    {
      "type": "text",
      "id": "panel_kicker",
      "label": "Panel eyebrow",
      "default": "Why shoppers start here"
    },
    {
      "type": "text",
      "id": "panel_title",
      "label": "Panel title",
      "default": "A homepage built for discovery, gifting, and quick trust."
    },
    {
      "type": "richtext",
      "id": "panel_copy",
      "label": "Panel copy",
      "default": "<p>Guide first-time visitors toward the right intention, product type, or gift path before they feel lost inside the catalog.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 16,
      "max": 72,
      "step": 4,
      "unit": "px",
      "label": "Side padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "trust_bullet",
      "name": "Trust bullet",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Shop with more confidence"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Use this space for concise trust-building support copy."
        }
      ]
    },
    {
      "type": "proof_item",
      "name": "Proof item",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Curated discovery"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Lead shoppers to categories, meanings, and gifting paths quickly."
        }
      ]
    },
    {
      "type": "shortcut",
      "name": "Shortcut",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop bracelets"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Conversion Intro"
    }
  ]
}
{% endschema %}
