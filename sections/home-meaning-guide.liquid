<div class="home-conversion-section home-meaning-guide section-block-{{ section.id }}">
  <div class="{% if section.settings.container == 'fullwidth' %}container-full{% elsif section.settings.container == '1770' %}container-1770{% elsif section.settings.container == '1170' %}container-1170{% else %}container{% endif %}">
    <div class="home-conversion-shell home-conversion-reveal" style="padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;">
      <div class="home-conversion-inner">
        {% if section.settings.eyebrow != blank %}
          <p class="home-conversion-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="home-conversion-heading" style="font-size: clamp(2rem, 3.3vw, 4rem);">{{ section.settings.title }}</h2>
        {% endif %}

        {% if section.settings.copy != blank %}
          <div class="home-conversion-copy rte" style="margin-top: 20px;">
            {{ section.settings.copy }}
          </div>
        {% endif %}

        <div class="home-meaning-grid" style="margin-top: 28px;">
          {% for block in section.blocks %}
            <div class="home-meaning-card" {{ block.shopify_attributes }}>
              {% if block.settings.kicker != blank %}
                <span class="home-meaning-card-kicker">{{ block.settings.kicker }}</span>
              {% endif %}

              {% if block.settings.title != blank %}
                <h3 class="home-meaning-card-title">{{ block.settings.title }}</h3>
              {% endif %}

              {% if block.settings.text != blank %}
                <div class="home-meaning-card-text rte">
                  {{ block.settings.text }}
                </div>
              {% endif %}

              {% if block.settings.link_label != blank %}
                <a class="home-meaning-card-link" {% if block.settings.link == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.link }}"{% endif %}>
                  {{ block.settings.link_label }}
                </a>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Home Meaning Guide",
  "tag": "section",
  "class": "section-home-meaning-guide",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Container",
      "default": "1770",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "1170", "label": "1170px" },
        { "value": "1770", "label": "1770px" },
        { "value": "fullwidth", "label": "Full width" }
      ]
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "A smarter way to browse"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "Help shoppers find the right piece by intention, stone, gifting moment, or wearing style."
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Intro copy",
      "default": "<p>Use this section to turn a large catalog into a guided discovery experience. The goal is not just to show products, but to make the next click feel obvious.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 16,
      "max": 72,
      "step": 4,
      "unit": "px",
      "label": "Side padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "guide_card",
      "name": "Guide card",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "Eyebrow",
          "default": "Guide"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Shop by intention"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Describe how this path helps shoppers choose faster and with more confidence.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Explore this path"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Meaning Guide"
    }
  ]
}
{% endschema %}
